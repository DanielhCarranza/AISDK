// swift-tools-version: 5.9
// The swift-tools-version declares the minimum version of Swift required to build this package.

import PackageDescription

let package = Package(
    name: "AISDK",
    platforms: [
        .iOS(.v18),
        .macOS(.v14),
        .watchOS(.v11),
        .tvOS(.v18)
    ],
    products: [
        // Core library (required for all other products)
        .library(
            name: "AISDK",
            targets: ["AISDK"]
        ),
        
        // Optional feature libraries
        .library(
            name: "AISDKChat",
            targets: ["AISDKChat"]
        ),
        
        .library(
            name: "AISDKVoice", 
            targets: ["AISDKVoice"]
        ),
        
        .library(
            name: "AISDKVision",
            targets: ["AISDKVision"]
        ),
        
        .library(
            name: "AISDKResearch",
            targets: ["AISDKResearch"]
        )
    ],
    dependencies: [
        // Network layer
        .package(url: "https://github.com/Alamofire/Alamofire.git", from: "5.8.0"),
        
        // JSON handling
        .package(url: "https://github.com/SwiftyJSON/SwiftyJSON.git", from: "5.0.0"),
        
        // Markdown rendering for chat UI
        .package(url: "https://github.com/gonzalezreal/swift-markdown-ui", from: "2.3.0"),
        
        // Charts for data visualization
        .package(url: "https://github.com/danielgindi/Charts.git", from: "5.0.0"),
        
        // LiveKit for vision features
        .package(url: "https://github.com/livekit/client-sdk-swift.git", from: "2.0.0"),
        
        // Development and documentation
        .package(url: "https://github.com/apple/swift-docc-plugin", from: "1.3.0"),
        
        // Testing utilities
        .package(url: "https://github.com/apple/swift-async-algorithms", from: "1.0.0")
    ],
    targets: [
        // MARK: - Core Target
        .target(
            name: "AISDK",
            dependencies: [
                "Alamofire",
                "SwiftyJSON"
            ],
            path: "Sources/AISDK",
            resources: [
                .process("Resources/Prompts"),
                .copy("Resources/PrivacyInfo.xcprivacy")
            ],
            swiftSettings: [
                .enableExperimentalFeature("StrictConcurrency"),
                .define("AISDK_VERSION", to: "\"1.0.0\"")
            ]
        ),
        
        // MARK: - Chat Target
        .target(
            name: "AISDKChat",
            dependencies: [
                "AISDK",
                .product(name: "MarkdownUI", package: "swift-markdown-ui"),
                .product(name: "Charts", package: "Charts")
            ],
            path: "Sources/AISDKChat",
            resources: [
                .process("Resources/Assets.xcassets")
            ]
        ),
        
        // MARK: - Voice Target
        .target(
            name: "AISDKVoice",
            dependencies: ["AISDK"],
            path: "Sources/AISDKVoice",
            swiftSettings: [
                .define("VOICE_NATIVE", .when(platforms: [.iOS, .macOS]))
            ]
        ),
        
        // MARK: - Vision Target
        .target(
            name: "AISDKVision",
            dependencies: [
                "AISDK",
                .product(name: "LiveKit", package: "client-sdk-swift")
            ],
            path: "Sources/AISDKVision"
        ),
        
        // MARK: - Research Target
        .target(
            name: "AISDKResearch",
            dependencies: ["AISDK"],
            path: "Sources/AISDKResearch"
        ),
        
        // MARK: - Test Targets
        .testTarget(
            name: "AISDKTests",
            dependencies: [
                "AISDK",
                .product(name: "AsyncAlgorithms", package: "swift-async-algorithms")
            ],
            path: "Tests/AISDKTests",
            resources: [
                .copy("TestResources/mock_responses.json"),
                .copy("TestResources/test_tools.json")
            ]
        ),
        
        .testTarget(
            name: "AISDKChatTests",
            dependencies: ["AISDKChat"],
            path: "Tests/AISDKChatTests"
        ),
        
        .testTarget(
            name: "AISDKVoiceTests",
            dependencies: ["AISDKVoice"],
            path: "Tests/AISDKVoiceTests"
        ),
        
        .testTarget(
            name: "AISDKVisionTests",
            dependencies: ["AISDKVision"],
            path: "Tests/AISDKVisionTests"
        ),
        
        .testTarget(
            name: "AISDKResearchTests",
            dependencies: ["AISDKResearch"],
            path: "Tests/AISDKResearchTests"
        ),
        
        // MARK: - Integration Tests
        .testTarget(
            name: "AISDKIntegrationTests",
            dependencies: [
                "AISDK",
                "AISDKChat",
                "AISDKVoice"
            ],
            path: "Tests/AISDKIntegrationTests"
        )
    ]
)

// MARK: - Development Configuration

#if DEBUG
package.targets.append(
    .executableTarget(
        name: "AISDKDemo",
        dependencies: [
            "AISDK",
            "AISDKChat",
            "AISDKVoice",
            "AISDKVision",
            "AISDKResearch"
        ],
        path: "Sources/AISDKDemo"
    )
)
#endif

// MARK: - Platform-Specific Configuration

for target in package.targets {
    if target.type == .regular || target.type == .test {
        target.swiftSettings = (target.swiftSettings ?? []) + [
            .enableUpcomingFeature("BareSlashRegexLiterals", .when(configuration: .debug)),
            .enableUpcomingFeature("ConciseMagicFile", .when(configuration: .debug)),
            .enableUpcomingFeature("ExistentialAny"),
            .enableUpcomingFeature("ForwardTrailingClosures"),
            .enableUpcomingFeature("ImplicitOpenExistentials"),
            .enableUpcomingFeature("DisableOutwardActorInference"),
            .unsafeFlags(["-strict-concurrency=complete"], .when(configuration: .debug))
        ]
    }
}

// MARK: - Custom Build Settings

// Example of conditional compilation for different platforms
#if os(iOS)
package.targets.first(where: { $0.name == "AISDKVoice" })?.swiftSettings?.append(
    .define("IOS_VOICE_ENHANCEMENTS")
)
#endif

// MARK: - Documentation Generation

// This configuration helps with generating documentation using swift-docc
package.targets.forEach { target in
    if target.type == .regular {
        target.swiftSettings = (target.swiftSettings ?? []) + [
            .unsafeFlags(["-emit-extension-block-symbols"], .when(configuration: .debug)),
            .unsafeFlags(["-emit-symbol-graph"], .when(configuration: .debug)),
            .unsafeFlags(["-emit-symbol-graph-dir", ".build/symbol-graphs"], .when(configuration: .debug))
        ]
    }
}

// MARK: - Example Apps Configuration

// You can extend this to add example applications
let exampleApps = [
    "ChatExample": ["AISDK", "AISDKChat"],
    "VoiceExample": ["AISDK", "AISDKVoice"],
    "VisionExample": ["AISDK", "AISDKVision"],
    "ResearchExample": ["AISDK", "AISDKResearch"],
    "FullExample": ["AISDK", "AISDKChat", "AISDKVoice", "AISDKVision", "AISDKResearch"]
]

